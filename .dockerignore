# =============================================================================
# .dockerignore — keep the Docker build context small and secure
# =============================================================================

# --- Version control & IDE ---
.git/
.gitignore
.vscode/
.idea/

# --- Python bytecode & caches ---
__pycache__/
*.pyc
*.pyo

# --- Virtual environments ---
venv/
env/
.build/

# --- Development / profiling / scripts ---
scripts/
profiles/
*.ipynb
.ipynb_checkpoints/
docs/

# --- Build artifacts & archives ---
*.tar
*.zip
*.tar.gz
!images_cache.tar.gz
*.log
*.cache

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Environment / secrets ---
.env
.env.*

# --- Images: raw folder excluded; the .tar.gz archive is used instead ---
data/images/

# --- Legacy ---
_image_extract/
_image_app/
